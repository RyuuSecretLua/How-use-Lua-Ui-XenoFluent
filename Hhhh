local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/RyuuSecretLua/XenoFluentUI-/refs/heads/main/Library%20lua"))()

local UI = Library.new({
	Title = "Uwu Hub",
})

local TabMain = UI:Tab({ Title = "Main" })
local TabPlayer = UI:Tab({ Title = "Player" })
local TabVisual = UI:Tab({ Title = "Visual" })
local TabMisc = UI:Tab({ Title = "Misc" })

TabMain:Section({ Title = "Automation" })

TabMain:Button({
	Title = "Auto Collect Orbs",
	Callback = function()
		local char = game.Players.LocalPlayer.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		for _, v in pairs(workspace:GetDescendants()) do
			if v.Name == "Orb" or v.Name == "orb" then
				pcall(firetouchinterest, hrp, v, 0)
			end
		end
	end
})

TabMain:Button({
	Title = "Auto Checkpoint",
	Callback = function()
		local char = game.Players.LocalPlayer.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		for i = 1, 999 do
			local cp = workspace:FindFirstChild("Checkpoint" .. i)
				or workspace:FindFirstChild("ClearStage" .. i)
			if cp then
				hrp.CFrame = cp:IsA("Model") and cp.PrimaryPart and cp.PrimaryPart.CFrame or CFrame.new(cp.Position)
				task.wait(0.1)
			end
		end
	end
})

TabMain:Section({ Title = "Remote" })

TabMain:Button({
	Title = "Fire All RemoteEvents",
	Callback = function()
		for _, v in pairs(game:GetDescendants()) do
			if v:IsA("RemoteEvent") then
				pcall(function() v:FireServer() end)
			end
		end
	end
})

TabMain:Button({
	Title = "Fire All RemoteFunctions",
	Callback = function()
		for _, v in pairs(game:GetDescendants()) do
			if v:IsA("RemoteFunction") then
				pcall(function() v:InvokeServer() end)
			end
		end
	end
})

TabPlayer:Section({ Title = "Movement" })

